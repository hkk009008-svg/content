#!/usr/bin/env bash
# send-event — write a protocol-v6.0 mailbox event with a correct filename +
# envelope, and stage it (explicit pathspec; never commits).
#
#   usage: send-event <from> <to> <kind> <subject...>   (body on stdin)
#
# The trailing "Cursor at send:" line is read from the SENDER's seen file at
# write time — it cannot drift from the file the way hand-written cursor
# prose did (the 2026-06-10 three-way divergence). Kinds are validated against
# the shared coordination/mailbox/kinds.txt registry.
set -euo pipefail

usage() { echo "usage: send-event <from> <to> <kind> <subject...>  (body on stdin)"; }

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

[ $# -ge 4 ] || { usage >&2; exit 2; }
FROM=$1; TO=$2; KIND=$3; shift 3; SUBJECT="$*"
ROOT=$(git rev-parse --show-toplevel)

# Seats: 4-seat protocol (two director-operator pairs). `all` is a broadcast
# TARGET only — never a sender. `coordinator` is the mirror: a send-only pseudo-
# seat — a valid <from>, never a <to>, no seen cursor (read-only oversight seat).
# Keep in sync with consume-events, check_coordination.py (_EVENT_NAME_RE frm)
# and scripts/status.py.
case "$FROM" in director|director2|operator|operator2|coordinator) ;; *) echo "send-event: bad <from>: $FROM (director|director2|operator|operator2|coordinator)" >&2; exit 2;; esac
case "$TO"   in director|director2|operator|operator2|all) ;; *) echo "send-event: bad <to>: $TO (director|director2|operator|operator2|all)" >&2; exit 2;; esac
[ "$FROM" != "$TO" ] || { echo "send-event: refusing self-addressed event" >&2; exit 2; }

KIND_FILE="$ROOT/coordination/mailbox/kinds.txt"
if [ ! -f "$KIND_FILE" ]; then
  echo "send-event: missing mailbox kind registry: $KIND_FILE" >&2
  exit 2
fi
if ! grep -Fxq -- "$KIND" "$KIND_FILE"; then
  echo "send-event: unknown kind '$KIND' (see $KIND_FILE)" >&2
  exit 2
fi

TS_DASH=$(date -u +%Y-%m-%dT%H-%M-%SZ)
TS_COLON="${TS_DASH:0:11}$(echo "${TS_DASH:11:8}" | tr '-' ':')Z"
REL="coordination/mailbox/sent/$TS_DASH-$FROM-to-$TO-$KIND.md"
F="$ROOT/$REL"
[ ! -e "$F" ] || { echo "send-event: $REL already exists (same-second collision) — retry" >&2; exit 3; }

FROM_TITLE="$(tr '[:lower:]' '[:upper:]' <<< "${FROM:0:1}")${FROM:1}"
TO_TITLE="$(tr '[:lower:]' '[:upper:]' <<< "${TO:0:1}")${TO:1}"
CURSOR=$(head -1 "$ROOT/coordination/mailbox/seen/$FROM.txt" 2>/dev/null || echo "unknown")
BODY=$(cat)

TMP=$(mktemp "$ROOT/coordination/mailbox/sent/.${TS_DASH}-${FROM}-to-${TO}-${KIND}.XXXXXX.tmp")
cleanup_tmp() { rm -f "$TMP"; }
trap cleanup_tmp EXIT

{
  printf '# %s → %s: %s\n\n' "$FROM_TITLE" "$TO_TITLE" "$SUBJECT"
  printf '**When:** %s · **From:** %s (online)\n\n' "$TS_COLON" "$FROM"
  if [ -n "$BODY" ]; then printf '%s\n\n' "$BODY"; fi
  printf 'Cursor at send: %s\n' "$CURSOR"
} > "$TMP"

mv "$TMP" "$F"
if ! git -C "$ROOT" add -- "$REL"; then
  rm -f "$F"
  echo "send-event: git add failed; removed $REL" >&2
  exit 1
fi
echo "created $REL (staged; commit with explicit pathspec)"
