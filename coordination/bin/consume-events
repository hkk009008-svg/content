#!/usr/bin/env bash
# consume-events — advance a role's mailbox cursor (seen/<role>.txt) to the
# newest event addressed to it (or an explicit --to target), and stage the
# cursor file (explicit pathspec; never commits).
#
#   usage: consume-events <director|director2|operator|operator2|coordinator|coordinator2> [--to <ISO-UTC timestamp>]
#
# This is the ONLY sanctioned writer of seen/*.txt under protocol v6.0: the
# cursor file is the single source of truth, and the advance rides the seat's
# next substantive commit (cursor folding). Refuses regressions and targets
# that match no real event — the two ways hand-edited cursors went wrong.
set -euo pipefail

usage() {
  echo "usage: consume-events <director|director2|operator|operator2|coordinator|coordinator2> [--to <timestamp>]"
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

ROLE=${1:-}
# 4-seat protocol (two director-operator pairs). `all` is a broadcast TARGET,
# not a consuming role — there is no seen/all.txt; every real seat consumes
# events addressed to itself OR to `all` (see addressed() below).
case "$ROLE" in director|director2|operator|operator2|coordinator|coordinator2) ;; *)
  usage >&2; exit 2;; esac
shift
TARGET=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --to)
      shift
      [ $# -gt 0 ] || { echo "consume-events: --to needs a timestamp" >&2; exit 2; }
      TARGET=$1
      shift
      ;;
    *)
      echo "consume-events: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ -n "$TARGET" ]; then
  case "$TARGET" in
    [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]Z) ;;
    [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]-[0-9][0-9]-[0-9][0-9]Z) ;;
    *) echo "consume-events: malformed --to timestamp: $TARGET" >&2; exit 2;;
  esac
fi

ROOT=$(git rev-parse --show-toplevel)
SENT="$ROOT/coordination/mailbox/sent"
SEEN="$ROOT/coordination/mailbox/seen/$ROLE.txt"
CUR=$(head -1 "$SEEN")

dash()  { echo "${1:0:11}$(echo "${1:11:8}" | tr ':' '-')Z"; }
colon() { echo "${1:0:11}$(echo "${1:11:8}" | tr '-' ':')Z"; }

addressed() { ls "$SENT" 2>/dev/null | grep -E -- "-to-($ROLE|all)-" | sort; }

if [ -n "$TARGET" ]; then
  TD=$(dash "$TARGET")
  addressed | grep -q "^$TD-" || {
    echo "consume-events: no event at $(colon "$TD") addressed to $ROLE" >&2; exit 2; }
else
  NEWEST=$(addressed | tail -1 | cut -c1-20)
  if [ -z "$NEWEST" ]; then
    echo "consume-events: no events addressed to $ROLE (no-op)"; exit 0
  fi
  TD=$NEWEST
fi

CURD=$(dash "$CUR")
if [ "$TD" = "$CURD" ]; then
  echo "cursor $ROLE: already at $(colon "$TD") (no-op)"; exit 0
fi
if [ "$TD" \< "$CURD" ]; then
  echo "consume-events: refusing cursor regression $CUR -> $(colon "$TD")" >&2; exit 2
fi

NEW=$(colon "$TD")
printf '%s\n' "$NEW" > "$SEEN"
git -C "$ROOT" add -- "coordination/mailbox/seen/$ROLE.txt"
UNREAD=$(addressed | cut -c1-20 | awk -v c="$TD" '$0 > c' | wc -l | tr -d ' ')
echo "cursor $ROLE: $CUR -> $NEW; unread now: $UNREAD (staged; fold into your next substantive commit)"
