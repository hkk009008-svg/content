# ---------------------------------------------------------------------------
# Cinema Pipeline — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# This list is authoritative — every variable read by config/settings.py
# appears below. The e2e tests require COMFYUI_SERVER_URL + at least one
# video API key + ELEVENLABS_API_KEY for the audio path.
# ---------------------------------------------------------------------------

# ComfyUI (set automatically by setup_runpod.sh, or point to remote instance)
COMFYUI_SERVER_URL=http://127.0.0.1:8188

# --- LLM providers (the cinema pipeline needs at least Anthropic + OpenAI) ---

# Anthropic — Claude (script generation, judging, chief director)
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o (script generation, judging, scene decomposition)
OPENAI_API_KEY=

# Google AI Studio — Gemini (vision QA, scene coherence)
GEMINI_API_KEY=

# Mistral — optional third-pass judge in the LLM ensemble
MISTRAL_API_KEY=

# --- Video Generation APIs (need at least one) ---

# Kling — primary video provider
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# FAL.ai — FLUX image fallback + video
FAL_KEY=

# LTX — lightweight video generation
LTX_API_KEY=

# Seedance — ByteDance video model
SEEDANCE_API_KEY=

# Google — Veo video generation (uses Vertex AI; see GOOGLE_CLOUD_* below)
GOOGLE_API_KEY=

# Runway — Gen4 video generation
RUNWAYML_API_SECRET=

# --- Audio Generation ---

# ElevenLabs — TTS narration + dialogue + foley sound effects
ELEVENLABS_API_KEY=

# --- Vertex AI (for Veo / managed Google Cloud workloads) ---

# Google Cloud project ID hosting the Vertex AI workloads
GOOGLE_CLOUD_PROJECT=

# Vertex AI region (defaults to us-central1 if unset)
GOOGLE_CLOUD_LOCATION=us-central1

# --- Research / Discovery ---

# Firecrawl — web scraping for trending-topic research
FIRECRAWL_API_KEY=

# Tavily — web search for trending-topic research
TAVILY_API_KEY=

# Pexels — stock footage fallback
PEXELS_API_KEY=

# --- Web server (optional — safe defaults if unset) ---

# Bind address for `python web_server.py`. Default is 127.0.0.1 (loopback
# only — accessible only from this machine's browser). Set to 0.0.0.0 to
# expose on the local network so you can reach the UI from your phone or
# another device on the same wifi. Note: 0.0.0.0 + wide-open CORS = any
# webpage you visit can read your project files via JS fetch; restrict
# CORS via WEB_CORS_ORIGINS if you flip this to 0.0.0.0.
WEB_BIND_HOST=127.0.0.1

# CORS allowlist — comma-separated origins permitted to call the API.
# Default (unset) is localhost dev origins only:
#   http://localhost:8080,http://localhost:5173
# Set to "*" to allow every origin (pre-hardening behavior). When binding
# to 0.0.0.0 above, add the LAN origin you want to use, e.g.
#   WEB_CORS_ORIGINS=http://localhost:8080,http://192.168.1.50:8080
WEB_CORS_ORIGINS=
