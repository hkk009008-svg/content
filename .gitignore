# Environments
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Python
__pycache__/
*.py[cod]
*$py.class

# Google Cloud OAuth API Secrets
client_secrets.json
token.pickle

# Cloud / API credentials
vertex-ai-key.json
*-key.json
*.pem

# Media Output (Prevents git from hanging on large video files)
*.mp4
*.mp3
*.wav
*.aiff

# Brainstorm visual-companion mockups (local, per-machine)
.superpowers/

# OS metadata
.DS_Store
**/.DS_Store
Thumbs.db

# Local databases
*.db
*.sqlite
*.sqlite3

# Build artifacts (compiled Swift binary lives at repo root)
MacStudio
dist/
web/dist/

# Node modules — must NEVER be tracked
node_modules/

# Local data directory (DBs, runtime caches)
data/*
!data/.gitkeep

# Per-project runtime artifacts (entire runtime project trees are not source)
projects/*
!projects/.gitkeep
domain/projects/*
!domain/projects/.gitkeep

# Pipeline run logs / scratch render output (per-clone runtime, not source)
# NB: ignore the CONTENTS (logs/*), not the dir itself, so the negation below can
# re-include specific files (git cannot re-include a file under an excluded DIR).
logs/*
# EXCEPTION: hardening-campaign discovery handoff artifacts are source-of-record
# (spec §3 — the committed JSON IS the refuter->coordinator boundary), not scratch.
!logs/discovery-*.json
# EXCEPTION: Wave 2+ close requires a committed product-oracle measurement artifact
# (ADR-027 FIX-5 / R-MEASURE), not a local scratch render.
!logs/product-oracle-*.json

# GitNexus index
.gitnexus

# Claude subagent worktrees (created at runtime, not source)
.claude/worktrees/

# State-update hook marker (per-clone runtime state, not source)
.claude/hooks/.last-state-head
.claude/hooks/.last-index-sync-*
.claude/hooks/.skip-worktree-cleared.log

# Claude skill evaluation workspaces/logs (local benchmark output, not source)
.claude/skill-eval/

# Codex local config and hook marker state (per-clone runtime state, not source)
.codex/config.toml
.codex/config.toml.bak-*
.codex/migrate-to-codex-report.txt
.codex/hooks/.last-state-head
.codex/hooks/.last-index-sync-*
.codex/hooks/.skip-worktree-cleared.log

# Hookify local rules (per-clone runtime guardrails, not source — see /hookify)
.claude/hookify.*.local.md

# Per-seat launch config (D-a per-seat GIT_INDEX_FILE/CLAUDE_SEAT; per-clone, not source)
.claude/launch.json
.claude/settings.local.json

# Local editor config (per-developer, not source)
.vscode/

# Auto-generated session snapshot (B-003 Option E, cycle 8). Hook
# regenerates this file on every Bash call from local git state; not
# meaningful to track in commit history (the historical versions in
# the chain prior to the cycle-8 cutover are inert).
STATE.md
# Auto-generated status dashboard snapshot (scripts/status.py --write).
# Local-only artifact; never commit.
STATUS.md
# v5.7 M1 — real-time presence signals (per-clone, like STATE.md; not source)
coordination/presence/
.claude/presence-seat.*
.codex/presence-seat.*
