# Environments
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Python
__pycache__/
*.py[cod]
*$py.class

# Google Cloud OAuth API Secrets
client_secrets.json
token.pickle

# Cloud / API credentials
vertex-ai-key.json
*-key.json
*.pem

# Media Output (Prevents git from hanging on large video files)
*.mp4
*.mp3
*.wav
*.aiff

# OS metadata
.DS_Store
**/.DS_Store
Thumbs.db

# Local databases
*.db
*.sqlite
*.sqlite3

# Build artifacts (compiled Swift binary lives at repo root)
MacStudio
dist/
web/dist/

# Node modules — must NEVER be tracked
node_modules/

# Local data directory (DBs, runtime caches)
data/*
!data/.gitkeep

# Per-project runtime artifacts (entire runtime project trees are not source)
projects/*
!projects/.gitkeep
domain/projects/*
!domain/projects/.gitkeep

# GitNexus index
.gitnexus

# Claude subagent worktrees (created at runtime, not source)
.claude/worktrees/

# State-update hook marker (per-clone runtime state, not source)
.claude/hooks/.last-state-head

# Hookify local rules (per-clone runtime guardrails, not source — see /hookify)
.claude/hookify.*.local.md

# Auto-generated session snapshot (B-003 Option E, cycle 8). Hook
# regenerates this file on every Bash call from local git state; not
# meaningful to track in commit history (the historical versions in
# the chain prior to the cycle-8 cutover are inert).
STATE.md
# Auto-generated status dashboard snapshot (scripts/status.py --write).
# Local-only artifact; never commit.
STATUS.md
# v5.7 M1 — real-time presence signals (per-clone, like STATE.md; not source)
coordination/presence/
