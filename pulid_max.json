{
  "_metadata": {
    "_meta": { "title": "MAX-QUALITY FLUX SCAFFOLD — N=8 adaptive halt, fp16 everywhere" },
    "_doc": "Loaded by quality_max.py. Dynamic patches by shot: prompt (122), seed (25), latent source (13), refs (93/200/810). Pod-availability probed at runtime; missing nodes pruned with rewiring fallbacks."
  },

  "112": {
    "inputs": { "unet_name": "FLUX1/flux1-dev-fp16.safetensors", "weight_dtype": "default" },
    "class_type": "UNETLoader",
    "_meta": { "title": "FLUX-Dev fp16 (no quantization)" }
  },
  "11": {
    "inputs": {
      "clip_name1": "t5xxl_fp16.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux",
      "device": "default"
    },
    "class_type": "DualCLIPLoader",
    "_meta": { "title": "Dual CLIP fp16 (T5-XXL + CLIP-L)" }
  },
  "10": {
    "inputs": { "vae_name": "ae.safetensors" },
    "class_type": "VAELoader",
    "_meta": { "title": "FLUX VAE (fp32 internal)" }
  },

  "700": {
    "inputs": {
      "lora_name": "PLACEHOLDER_char.safetensors",
      "strength_model": 1.0,
      "strength_clip": 1.0,
      "model": ["112", 0],
      "clip": ["11", 0]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "Per-character LoRA (rank 32, fp16) — injected at runtime" }
  },

  "97": {
    "inputs": { "provider": "CUDA" },
    "class_type": "PulidInsightFaceLoader",
    "_meta": { "title": "InsightFace antelopev2 (face analysis)" }
  },
  "99": {
    "inputs": { "pulid_file": "pulid_flux_v0.9.1.safetensors" },
    "class_type": "PulidFluxModelLoader",
    "_meta": { "title": "PuLID-FLUX v0.9.1 (correct file, not SDXL)" }
  },
  "101": {
    "inputs": {},
    "class_type": "PulidFluxEvaClipLoader",
    "_meta": { "title": "EVA-CLIP for PuLID" }
  },
  "93": {
    "inputs": { "image": "PLACEHOLDER_face_ref.jpg" },
    "class_type": "LoadImage",
    "_meta": { "title": "Face anchor — primary reference" }
  },
  "100": {
    "inputs": {
      "weight": 0.85,
      "start_at": 0.0,
      "end_at": 0.9,
      "fusion": "mean",
      "fusion_weight_max": 1.0,
      "fusion_weight_min": 0.0,
      "train_step": 1000,
      "use_gray": true,
      "model": ["700", 0],
      "pulid_flux": ["99", 0],
      "eva_clip": ["101", 0],
      "face_analysis": ["97", 0],
      "image": ["93", 0]
    },
    "class_type": "ApplyPulidFlux",
    "_meta": { "title": "Apply PuLID-FLUX (FLUX-native — not SDXL ApplyPulid)" }
  },

  "301": {
    "inputs": { "scale": 3.0, "adaptive_scale": 0.0, "model": ["100", 0] },
    "class_type": "PerturbedAttentionGuidance",
    "_meta": { "title": "PAG @ 3.0 — perturbed self-attention" }
  },
  "770": {
    "inputs": {
      "double_layers": "7,8,9",
      "single_layers": "10,11",
      "scale": 2.5,
      "start_percent": 0.01,
      "end_percent": 0.20,
      "rescaling_scale": 0.0,
      "model": ["301", 0]
    },
    "class_type": "SkipLayerGuidanceDiT",
    "_meta": { "title": "SLG (Skip Layer Guidance) @ DiT layers 7-9/10-11" }
  },
  "772": {
    "inputs": { "b1": 1.3, "b2": 1.4, "s1": 0.9, "s2": 0.2, "model": ["770", 0] },
    "class_type": "FreeU_V2",
    "_meta": { "title": "FreeU v2 — skip-connection amplification" }
  },
  "740": {
    "inputs": { "model": ["772", 0] },
    "class_type": "DifferentialDiffusion",
    "_meta": { "title": "Differential Diffusion — region-aware denoise (auto soft mask)" }
  },

  "122": {
    "inputs": { "text": "PLACEHOLDER_prompt", "clip": ["700", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Text encode (uses LoRA-patched CLIP)" }
  },
  "60": {
    "inputs": { "guidance": 3.5, "conditioning": ["122", 0] },
    "class_type": "FluxGuidance",
    "_meta": { "title": "FluxGuidance — set per shot type by workflow_selector" }
  },

  "400": {
    "inputs": { "image": "PLACEHOLDER_prev_shot.jpg" },
    "class_type": "LoadImage",
    "_meta": { "title": "Previous shot — for ControlNet + Redux + img2img" }
  },
  "401": {
    "inputs": { "image": ["400", 0], "ckpt_name": "depth_anything_v2_vitl_fp16.safetensors", "resolution": 518 },
    "class_type": "DepthAnythingV2Preprocessor",
    "_meta": { "title": "DepthAnything V2 (native 518px, upscaled by model)" }
  },
  "403": {
    "inputs": { "control_net_name": "FLUX.1/Shakker-Labs-Union-Pro/diffusion_pytorch_model.safetensors" },
    "class_type": "ControlNetLoader",
    "_meta": { "title": "FLUX Union CN Pro (Shakker-Labs)" }
  },
  "402": {
    "inputs": { "type": "depth", "control_net": ["403", 0] },
    "class_type": "SetUnionControlNetType",
    "_meta": { "title": "Union CN type=depth" }
  },
  "404": {
    "inputs": {
      "positive": ["60", 0],
      "negative": ["60", 0],
      "control_net": ["402", 0],
      "image": ["401", 0],
      "vae": ["10", 0],
      "strength": 0.40,
      "start_percent": 0.0,
      "end_percent": 0.50
    },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply CN-Depth @ 0.40, end 50%" }
  },

  "410": {
    "inputs": { "image": ["400", 0], "low_threshold": 0.08, "high_threshold": 0.18, "resolution": 1024 },
    "class_type": "CannyEdgePreprocessor",
    "_meta": { "title": "Canny edge (prev shot) — edge coherence" }
  },
  "411": {
    "inputs": { "type": "canny", "control_net": ["403", 0] },
    "class_type": "SetUnionControlNetType",
    "_meta": { "title": "Union CN type=canny" }
  },
  "412": {
    "inputs": {
      "positive": ["404", 0],
      "negative": ["404", 1],
      "control_net": ["411", 0],
      "image": ["410", 0],
      "vae": ["10", 0],
      "strength": 0.15,
      "start_percent": 0.0,
      "end_percent": 0.40
    },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply CN-Canny @ 0.15 (chained after depth)" }
  },

  "420": {
    "inputs": {
      "image": ["400", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024,
      "bbox_detector": "yolox_l.onnx",
      "pose_estimator": "dw-ll_ucoco_384.onnx"
    },
    "class_type": "DWPreprocessor",
    "_meta": { "title": "DWPose (body+hand+face landmarks)" }
  },
  "421": {
    "inputs": { "type": "openpose", "control_net": ["403", 0] },
    "class_type": "SetUnionControlNetType",
    "_meta": { "title": "Union CN type=openpose" }
  },
  "422": {
    "inputs": {
      "positive": ["412", 0],
      "negative": ["412", 1],
      "control_net": ["421", 0],
      "image": ["420", 0],
      "vae": ["10", 0],
      "strength": 0.35,
      "start_percent": 0.0,
      "end_percent": 0.50
    },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply CN-Pose @ 0.35 (only when char in frame)" }
  },

  "431": {
    "inputs": { "type": "tile", "control_net": ["403", 0] },
    "class_type": "SetUnionControlNetType",
    "_meta": { "title": "Union CN type=tile" }
  },
  "432": {
    "inputs": {
      "positive": ["422", 0],
      "negative": ["422", 1],
      "control_net": ["431", 0],
      "image": ["400", 0],
      "vae": ["10", 0],
      "strength": 0.25,
      "start_percent": 0.0,
      "end_percent": 0.60
    },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply CN-Tile @ 0.25 (texture preservation, raw prev shot)" }
  },

  "800": {
    "inputs": { "style_model_name": "flux1-redux-dev.safetensors" },
    "class_type": "StyleModelLoader",
    "_meta": { "title": "FLUX Redux style model" }
  },
  "801": {
    "inputs": { "clip_name": "sigclip_vision_patch14_384.safetensors" },
    "class_type": "CLIPVisionLoader",
    "_meta": { "title": "SigCLIP-Vision (Redux companion)" }
  },
  "810": {
    "inputs": { "image": "PLACEHOLDER_style_ref.jpg" },
    "class_type": "LoadImage",
    "_meta": { "title": "Style reference (curated production look)" }
  },
  "803": {
    "inputs": { "crop": "center", "clip_vision": ["801", 0], "image": ["810", 0] },
    "class_type": "CLIPVisionEncode",
    "_meta": { "title": "CLIP-Vision encode style ref" }
  },
  "804": {
    "inputs": {
      "image_strength": "high",
      "conditioning": ["432", 0],
      "style_model": ["800", 0],
      "clip_vision_output": ["803", 0]
    },
    "class_type": "StyleModelApplyAdvanced",
    "_meta": { "title": "Apply Redux @ high strength (end 50%)" }
  },

  "25": {
    "inputs": { "noise_seed": 42 },
    "class_type": "RandomNoise",
    "_meta": { "title": "Seed — overridden per candidate (best-of-N)" }
  },
  "16": {
    "inputs": { "sampler_name": "dpmpp_3m_sde_gpu" },
    "class_type": "KSamplerSelect",
    "_meta": { "title": "DPM++ 3M SDE GPU (highest-order solver)" }
  },
  "17": {
    "inputs": { "model_type": "FLUX", "steps": 28, "denoise": 1.0 },
    "class_type": "OptimalStepsScheduler",
    "_meta": { "title": "OptimalSteps scheduler — FLUX-native sigmas (AYS is FLUX-incompatible on the pod)" }
  },
  "780": {
    "inputs": {
      "sampler": ["16", 0],
      "detail_amount": 0.5,
      "start": 0.20,
      "end": 0.70,
      "bias": 0.5,
      "exponent": 1.0,
      "start_offset": 0.0,
      "end_offset": 0.0,
      "fade": 0.0,
      "smooth": true,
      "cfg_scale_override": 0.0
    },
    "class_type": "DetailDaemonSamplerNode",
    "_meta": { "title": "DetailDaemon — mid-sampling sigma injection" }
  },
  "22": {
    "inputs": { "model": ["740", 0], "conditioning": ["804", 0] },
    "class_type": "BasicGuider",
    "_meta": { "title": "Guider — model + final conditioning (CN+Redux)" }
  },

  "102": {
    "inputs": { "width": 1024, "height": 576, "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty latent — default 1024x576 (16:9 native FLUX)" }
  },
  "200": {
    "inputs": { "image": "PLACEHOLDER_init.jpg" },
    "class_type": "LoadImage",
    "_meta": { "title": "Init image (img2img mode)" }
  },
  "201": {
    "inputs": { "pixels": ["200", 0], "vae": ["10", 0] },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE encode init (img2img)" }
  },
  "250": {
    "inputs": { "samples1": ["201", 0], "samples2": ["102", 0], "ratio": 0.15 },
    "class_type": "LatentBlend",
    "_meta": { "title": "Latent blend — carry color/lighting precision from prev shot" }
  },

  "13": {
    "inputs": {
      "noise": ["25", 0],
      "guider": ["22", 0],
      "sampler": ["780", 0],
      "sigmas": ["17", 0],
      "latent_image": ["102", 0]
    },
    "class_type": "SamplerCustomAdvanced",
    "_meta": { "title": "Sampler Pass 1 — latent_image rewired by quality_max" }
  },

  "8": {
    "inputs": { "samples": ["13", 0], "vae": ["10", 0] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE decode Pass 1" }
  },

  "900": {
    "inputs": { "samples": ["13", 0], "upscale_method": "nearest-exact", "scale_by": 1.5 },
    "class_type": "LatentUpscaleBy",
    "_meta": { "title": "Latent upscale 1.5x for hires-fix" }
  },
  "901": {
    "inputs": {
      "noise": ["25", 0],
      "guider": ["22", 0],
      "sampler": ["16", 0],
      "sigmas": ["17", 0],
      "latent_image": ["900", 0]
    },
    "class_type": "SamplerCustomAdvanced",
    "_meta": { "title": "Sampler Pass 2 (hires-fix @ denoise 0.4, 18 steps — set by quality_max)" }
  },
  "902": {
    "inputs": { "samples": ["901", 0], "vae": ["10", 0] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE decode Pass 2 (hires-fix output)" }
  },

  "606": {
    "inputs": { "model_name": "bbox/face_yolov8m.pt" },
    "class_type": "UltralyticsDetectorProvider",
    "_meta": { "title": "BBOX detector (face_yolov8m) — provides BBOX_DETECTOR object" }
  },
  "607": {
    "inputs": { "model_name": "sam_vit_b_01ec64.pth", "device_mode": "AUTO" },
    "class_type": "SAMLoader",
    "_meta": { "title": "SAM loader (vit_b) — provides SAM_MODEL object" }
  },
  "600": {
    "inputs": {
      "image": ["902", 0],
      "model": ["740", 0],
      "clip": ["700", 1],
      "vae": ["10", 0],
      "positive": ["804", 0],
      "negative": ["804", 0],
      "bbox_detector": ["606", 0],
      "sam_model_opt": ["607", 0],
      "guide_size": 1024,
      "guide_size_for": true,
      "max_size": 2048,
      "seed": 42,
      "steps": 20,
      "cfg": 3.5,
      "sampler_name": "dpmpp_3m_sde_gpu",
      "scheduler": "sgm_uniform",
      "denoise": 0.35,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1
    },
    "class_type": "FaceDetailer",
    "_meta": { "title": "FaceDetailer @ 1024 (Impact Pack) — face region re-denoise" }
  },

  "610": {
    "inputs": {
      "enabled": true,
      "input_image": ["600", 0],
      "source_image": ["93", 0],
      "swap_model": "inswapper_128.onnx",
      "facedetection": "retinaface_resnet50",
      "face_restore_model": "codeformer-v0.1.0.pth",
      "face_restore_visibility": 1.0,
      "codeformer_weight": 0.5,
      "detect_gender_input": "no",
      "detect_gender_source": "no",
      "input_faces_index": "0",
      "source_faces_index": "0",
      "input_faces_order": "left-right",
      "source_faces_order": "left-right",
      "console_log_level": 1
    },
    "class_type": "ReActorFaceSwap",
    "_meta": { "title": "ReActor + CodeFormer (identity rescue, weight 0.5)" }
  },

  "505": {
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "SDXL base for SUPIR (provides model/clip/vae)" }
  },
  "500": {
    "inputs": {
      "supir_model": "SUPIR-v0Q_fp16.safetensors",
      "fp8_unet": false,
      "diffusion_dtype": "fp16",
      "high_vram": false,
      "model": ["505", 0],
      "clip": ["505", 1],
      "vae": ["505", 2]
    },
    "class_type": "SUPIR_model_loader_v2",
    "_meta": { "title": "SUPIR-v0Q (portrait-tuned, fp16) — kijai v2 API" }
  },
  "501": {
    "inputs": {
      "SUPIR_VAE": ["500", 1],
      "image": ["610", 0],
      "use_tiled_vae": true,
      "encoder_tile_size": 512,
      "decoder_tile_size": 64,
      "encoder_dtype": "auto"
    },
    "class_type": "SUPIR_first_stage",
    "_meta": { "title": "SUPIR first-stage encode (tiled VAE)" }
  },
  "504": {
    "inputs": {
      "SUPIR_model": ["500", 0],
      "latents": ["501", 2],
      "positive_prompt": "high quality, sharp focus, fine detail, photorealistic",
      "negative_prompt": "blurry, low quality, deformed, artifacts, oversaturated"
    },
    "class_type": "SUPIR_conditioner",
    "_meta": { "title": "SUPIR conditioner (pos/neg cond from denoised latents)" }
  },
  "502": {
    "inputs": {
      "SUPIR_model": ["500", 0],
      "latents": ["501", 2],
      "positive": ["504", 0],
      "negative": ["504", 1],
      "seed": 42,
      "steps": 50,
      "cfg_scale_start": 4.0,
      "cfg_scale_end": 4.0,
      "EDM_s_churn": 5,
      "s_noise": 1.003,
      "DPMPP_eta": 1.0,
      "control_scale_start": 1.0,
      "control_scale_end": 1.0,
      "restore_cfg": -1.0,
      "keep_model_loaded": true,
      "sampler": "RestoreEDMSampler",
      "sampler_tile_size": 1024,
      "sampler_tile_stride": 512
    },
    "class_type": "SUPIR_sample",
    "_meta": { "title": "SUPIR sample (50 steps, EDM restore)" }
  },
  "503": {
    "inputs": {
      "SUPIR_VAE": ["500", 1],
      "latents": ["502", 0],
      "use_tiled_vae": true,
      "decoder_tile_size": 64
    },
    "class_type": "SUPIR_decode",
    "_meta": { "title": "SUPIR decode (tiled)" }
  },

  "950": {
    "inputs": { "upscale_method": "lanczos", "width": 3840, "height": 2160, "crop": "disabled", "image": ["503", 0] },
    "class_type": "ImageScale",
    "_meta": { "title": "Downsample to 4K master (supersampling AA benefit)" }
  },

  "9": {
    "inputs": { "filename_prefix": "FLUX_MAX", "images": ["950", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save final" }
  }
}
